# ============================================================
# YouTube Knowledge Engine — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- LLM (Groq) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.1

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
EMBEDDING_CACHE_DIR=./data/cache/embeddings

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=youtube_knowledge_base

# --- Processing ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
FRAME_EXTRACTION_FPS=0.5
MAX_FRAMES_PER_VIDEO=20
BLIP_MODEL=Salesforce/blip-image-captioning-base
BLIP_ENABLED=true

# --- Retrieval ---
TOP_K=5
HYBRID_ALPHA=0.7
RERANKER_ENABLED=true
BM25_K1=1.5
BM25_B=0.75

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false
SECRET_KEY=change_me_to_a_secure_random_string
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# --- Frontend ---
STREAMLIT_PORT=8501
BACKEND_URL=http://localhost:8000

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./data/logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# --- yt-dlp ---
YTDLP_COOKIES_FILE=
YTDLP_MAX_VIDEOS=500
YTDLP_SLEEP_INTERVAL=1

# --- Async / Concurrency ---
INGESTION_CONCURRENCY=4
EMBEDDING_CONCURRENCY=8

